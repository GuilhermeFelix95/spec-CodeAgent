  "repository": {
    "type": "git",
    "url": "git+https://github.com/igoruehara/spec-driven.git"
  },
  "bugs": {
    "url": "https://github.com/igoruehara/spec-driven/issues"
  },
  "homepage": "https://github.com/igoruehara/spec-driven#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "test:setup": "node bin/cli.mjs .tmp-codeagent-test --all --force --yes",
    "prepublishOnly": "node bin/cli.mjs .tmp-codeagent-test --all --force --yes"
  }
