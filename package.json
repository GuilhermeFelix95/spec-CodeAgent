{
  "name": "spec-codeagent",
  "version": "0.1.9",
  "description": "CodeAgent para agentes de IA (Codex, Cursor, Copilot, Gemini, Windsurf) - Lean Inception + DDD + documentos de design técnico, com skills, templates e portões de qualidade. Use via npx em qualquer projeto.",
  "type": "module",
  "bin": {
    "spec-driven": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "template",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "ddd",
    "lean-inception",
    "codex",
    "agents-md",
    "cursor",
    "copilot",
    "gemini",
    "windsurf",
    "agent-skills"
  ],
  "author": "Guilherme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GuilhermeFelix95/Spec-CodeAgent.git"
  },
  "bugs": {
    "url": "https://github.com/GuilhermeFelix95/Spec-CodeAgent/issues"
  },
  "homepage": "https://github.com/GuilhermeFelix95/Spec-CodeAgent#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "test:setup": "node bin/cli.mjs .tmp-codeagent-test --all --force --yes",
    "prepublishOnly": "node bin/cli.mjs .tmp-codeagent-test --all --force --yes"
  }
}
